/**
 * Backoffice Service CI/CD Pipeline
 * 
 * Two-phase pipeline as required:
 * Phase 1: Test - Run tests, lint and code quality checks
 * Phase 2: Build - Build artifacts and Docker images
 */
pipeline {
    agent any

    environment {
        SERVICE_NAME    = 'backoffice'
        DOCKER_REGISTRY = 'ghcr.io'
        DOCKER_IMAGE    = "${DOCKER_REGISTRY}/nashtech-garage/yas-${SERVICE_NAME}"
        NODE_OPTIONS    = '--max-old-space-size=4096'
    }

    tools {
        nodejs 'nodejs-20'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 20, unit: 'MINUTES')
    }

    stages {
        // Guard: skip entirely if nothing in this service changed.
        stage('CI') {
            when {
                anyOf {
                    changeset 'backoffice/**'
                    expression { return currentBuild.changeSets.isEmpty() }
                }
            }
            stages {
                stage('Install Dependencies') {
                    steps {
                        dir('backoffice') {
                            sh 'npm ci --no-optional'
                        }
                    }
                }

                // ─── Phase 1: Test ─────────────────────────────────────────
                stage('Phase 1: Test') {
                    parallel {
                        stage('Unit Tests') {
                            steps {
                                dir('backoffice') {
                                    sh '''
                                        if node -e "const p=require('./package.json'); const hasJest=Boolean((p.devDependencies&&p.devDependencies.jest)||(p.dependencies&&p.dependencies.jest)||(p.scripts&&p.scripts.test)); process.exit(hasJest?0:1)"; then
                                            npx jest --coverage --ci --reporters=default --reporters=jest-junit
                                        else
                                            echo 'No Jest configuration found in backoffice/package.json. Skipping unit tests.'
                                        fi
                                    '''
                                }
                            }
                            post {
                                always {
                                    junit testResults: 'backoffice/junit.xml',
                                          allowEmptyResults: true
                                    publishHTML([
                                        allowMissing: true,
                                        alwaysLinkToLastBuild: true,
                                        keepAll: true,
                                        reportDir: 'backoffice/coverage/lcov-report',
                                        reportFiles: 'index.html',
                                        reportName: 'Backoffice Coverage Report'
                                    ])
                                }
                            }
                        }

                        stage('Lint & Code Quality') {
                            steps {
                                dir('backoffice') {
                                    sh 'npm run lint || true'
                                    sh 'npx prettier --check . || true'
                                }
                            }
                        }

                        stage('Security Audit') {
                            steps {
                                dir('backoffice') {
                                    sh 'npm audit --omit=dev || true'
                                }
                            }
                        }
                    }
                }
                // ─── Phase 2: Build ────────────────────────────────────────
                stage('Phase 2: Build') {
                    stages {
                        stage('Build Application') {
                            steps {
                                dir('backoffice') {
                                    sh 'npm run build'
                                }
                            }
                        }

                        stage('Build & Push Docker Image') {
                            when { 
                                anyOf {
                                    branch 'main'
                                    branch 'develop'
                                }
                            }
                            steps {
                                withCredentials([usernamePassword(
                                    credentialsId: 'docker-registry-credentials',
                                    usernameVariable: 'DOCKER_USER',
                                    passwordVariable: 'DOCKER_PASS'
                                )]) {
                                    sh """
                                        echo "\$DOCKER_PASS" | docker login ${DOCKER_REGISTRY} -u "\$DOCKER_USER" --password-stdin
                                        docker build -t ${DOCKER_IMAGE}:latest -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ./backoffice
                                        docker push ${DOCKER_IMAGE}:latest
                                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                                        docker logout ${DOCKER_REGISTRY}
                                    """
                                }
                            }
                        }
                    }
                }
            } // end nested stages
        } // end stage('CI')
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "✓ Backoffice service build completed successfully"
        }
        failure {
            echo "✗ Backoffice service build failed"
        }
    }
}
