pipeline {
    agent any

    environment {
        SERVICE_NAME    = 'backoffice'
        DOCKER_REGISTRY = 'ghcr.io'
        DOCKER_IMAGE    = "${DOCKER_REGISTRY}/nashtech-garage/yas-${SERVICE_NAME}"
        NODE_OPTIONS    = '--max-old-space-size=4096'
    }

    tools {
        nodejs 'nodejs-20'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 20, unit: 'MINUTES')
    }

    stages {
        // Guard: skip entirely if nothing in this service changed.
        // changeSets is empty on first scan of a new branch — always build then.
        // For PR builds Jenkins automatically compares against the target branch.
        stage('CI') {
            when {
                anyOf {
                    changeset 'backoffice/**'
                    expression { return currentBuild.changeSets.isEmpty() }
                }
            }
            stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('backoffice') {
                    sh 'npm ci'
                }
            }
        }

        stage('Build') {
            steps {
                dir('backoffice') {
                    sh 'npm run build'
                }
            }
        }

        stage('Test') {
            steps {
                dir('backoffice') {
                    // jest-junit generates JUnit XML; coverage written to coverage/
                    sh 'npx jest --coverage --ci --reporters=default --reporters=jest-junit || true'
                }
            }
            post {
                always {
                    junit testResults: 'backoffice/junit.xml',
                          allowEmptyResults: true
                    publishHTML([
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'backoffice/coverage/lcov-report',
                        reportFiles: 'index.html',
                        reportName: 'Backoffice Coverage Report'
                    ])
                }
            }
        }

        stage('Lint') {
            steps {
                dir('backoffice') {
                    sh 'npm run lint'
                }
            }
        }

        stage('Prettier Check') {
            steps {
                dir('backoffice') {
                    sh 'npx prettier --check .'
                }
            }
        }

        stage('Audit') {
            steps {
                dir('backoffice') {
                    // audit production deps only, warn on failure
                    sh 'npm audit --omit=dev || true'
                }
            }
        }

        stage('Docker Build & Push') {
            when { branch 'main' }
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-registry-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh """
                        echo "\$DOCKER_PASS" | docker login ${DOCKER_REGISTRY} -u "\$DOCKER_USER" --password-stdin
                        docker build -t ${DOCKER_IMAGE}:latest -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ./backoffice
                        docker push ${DOCKER_IMAGE}:latest
                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        docker logout ${DOCKER_REGISTRY}
                    """
                }
            }
        }
            } // end nested stages
        } // end stage('CI')
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo "Build failed for service: ${SERVICE_NAME}"
        }
    }
}
