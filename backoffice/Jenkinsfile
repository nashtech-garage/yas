/**
 * Backoffice Service CI/CD
 * 
 * Dual-mode Jenkinsfile:
 * 1. Can run standalone as a pipeline
 * 2. Can be loaded by master orchestrator pipeline
 */

// ─── Shared Build Logic ─────────────────────────────────────────────────────────
def runBuild(String serviceName) {
    echo ">>> Checkout"
    checkout scm

    echo ">>> Install Dependencies"
    dir(serviceName) {
        sh 'npm ci'
    }

    echo ">>> Build"
    dir(serviceName) {
        sh 'npm run build'
    }

    echo ">>> Test"
    dir(serviceName) {
        sh 'npx jest --coverage --ci --reporters=default --reporters=jest-junit || true'
    }
    junit testResults: "${serviceName}/junit.xml", allowEmptyResults: true
    publishHTML([
        allowMissing: true,
        alwaysLinkToLastBuild: true,
        keepAll: true,
        reportDir: "${serviceName}/coverage/lcov-report",
        reportFiles: 'index.html',
        reportName: "${serviceName.capitalize()} Coverage Report"
    ])

    echo ">>> Lint"
    dir(serviceName) {
        sh 'npm run lint'
    }

    echo ">>> Prettier Check"
    dir(serviceName) {
        sh 'npx prettier --check .'
    }

    echo ">>> Audit"
    dir(serviceName) {
        sh 'npm audit --omit=dev || true'
    }

    if (env.BRANCH_NAME == 'main') {
        echo ">>> Docker Build & Push"
        withCredentials([usernamePassword(
            credentialsId: 'docker-registry-credentials',
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
        )]) {
            sh """
                DOCKER_REGISTRY='ghcr.io'
                DOCKER_IMAGE="\${DOCKER_REGISTRY}/nashtech-garage/yas-${serviceName}"
                echo "\$DOCKER_PASS" | docker login \${DOCKER_REGISTRY} -u "\$DOCKER_USER" --password-stdin
                docker build -t \${DOCKER_IMAGE}:latest -t \${DOCKER_IMAGE}:${BUILD_NUMBER} ./${serviceName}
                docker push \${DOCKER_IMAGE}:latest
                docker push \${DOCKER_IMAGE}:${BUILD_NUMBER}
                docker logout \${DOCKER_REGISTRY}
            """
        }
    }
}

// ─── Check if loaded by master orchestrator ─────────────────────────────────────
if (binding.hasVariable('LOADED_BY_MASTER')) {
    // Called from master pipeline - just return this for loading
    return this
}

// ─── Standalone Pipeline Mode ───────────────────────────────────────────────────
pipeline {
    agent any

    environment {
        SERVICE_NAME    = 'backoffice'
        DOCKER_REGISTRY = 'ghcr.io'
        DOCKER_IMAGE    = "${DOCKER_REGISTRY}/nashtech-garage/yas-${SERVICE_NAME}"
        NODE_OPTIONS    = '--max-old-space-size=4096'
    }

    tools {
        nodejs 'nodejs-20'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 20, unit: 'MINUTES')
    }

    stages {
        stage('CI') {
            when {
                anyOf {
                    changeset 'backoffice/**'
                    expression { return currentBuild.changeSets.isEmpty() }
                }
            }
            steps {
                script {
                    runBuild('backoffice')
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo "Build failed for service: ${SERVICE_NAME}"
        }
    }
}
