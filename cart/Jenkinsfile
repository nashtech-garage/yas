/**
 * Cart Service CI/CD Build Functions
 * 
 * This file contains build logic that can be loaded by master orchestrator.
 * For standalone pipeline, see cart/Jenkinsfile.standalone (if needed)
 */

// ─── Build Logic ────────────────────────────────────────────────────────────────
def runBuild(String serviceName) {
    echo ">>> Checkout"
    checkout scm

    echo ">>> Build"
    sh "mvn clean install -pl ${serviceName} -am -DskipTests"

    echo ">>> Test"
    sh "mvn test jacoco:report -pl ${serviceName} -am"
    junit testResults: "${serviceName}/**/surefire-reports/TEST*.xml", allowEmptyResults: true
    jacoco(
        execPattern: "${serviceName}/target/jacoco.exec",
        classPattern: "${serviceName}/target/classes",
        sourcePattern: "${serviceName}/src/main/java",
        inclusionPattern: '**/*.class',
        changeBuildStatus: false
    )

    echo ">>> Checkstyle"
    sh "mvn checkstyle:checkstyle -pl ${serviceName} -am -Dcheckstyle.output.file=${serviceName}-checkstyle-result.xml"

    echo ">>> OWASP Dependency Check"
    sh "mvn -pl ${serviceName} org.owasp:dependency-check-maven:check -DfailBuildOnCVSS=7 || true"
    dependencyCheckPublisher pattern: "${serviceName}/target/dependency-check-report.xml", allowEmptyResults: true

    if (env.BRANCH_NAME == 'main') {
        echo ">>> Docker Build & Push"
        withCredentials([usernamePassword(
            credentialsId: 'docker-registry-credentials',
            usernameVariable: 'DOCKER_USER',
            passwordVariable: 'DOCKER_PASS'
        )]) {
            sh """
                DOCKER_REGISTRY='ghcr.io'
                DOCKER_IMAGE="\${DOCKER_REGISTRY}/nashtech-garage/yas-${serviceName}"
                echo "\$DOCKER_PASS" | docker login \${DOCKER_REGISTRY} -u "\$DOCKER_USER" --password-stdin
                docker build -t \${DOCKER_IMAGE}:latest -t \${DOCKER_IMAGE}:${BUILD_NUMBER} ./${serviceName}
                docker push \${DOCKER_IMAGE}:latest
                docker push \${DOCKER_IMAGE}:${BUILD_NUMBER}
                docker logout \${DOCKER_REGISTRY}
            """
        }
    }
}

// Export for loading
return this
