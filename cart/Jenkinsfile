/**
 * Cart Service CI/CD Pipeline
 * 
 * Two-phase pipeline as required:
 * Phase 1: Test - Run tests and code quality checks
 * Phase 2: Build - Build artifacts and Docker images
 */
pipeline {
    agent any
    
    environment {
        SERVICE_NAME    = 'cart'
        DOCKER_REGISTRY = 'ghcr.io'
        DOCKER_IMAGE    = "${DOCKER_REGISTRY}/nashtech-garage/yas-${SERVICE_NAME}"
    }

    tools {
        jdk   'jdk-21'
        maven 'maven-3'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }
    stages {
        // Guard: skip this pipeline entirely if nothing in this service changed.
        stage('CI') {
            when {
                anyOf {
                    changeset 'cart/**'
                    changeset 'pom.xml'
                    expression { return currentBuild.changeSets.isEmpty() }
                }
            }
            stages {
                // ─── Phase 1: Test ─────────────────────────────────────────
                stage('Phase 1: Test') {
                    parallel {
                        stage('Unit Tests') {
                            steps {
                                sh 'mvn test jacoco:report -pl cart -am'
                            }
                            post {
                                always {
                                    junit testResults: 'cart/**/surefire-reports/TEST*.xml',
                                          allowEmptyResults: true
                                    jacoco(
                                        execPattern: 'cart/target/jacoco.exec',
                                        classPattern: 'cart/target/classes',
                                        sourcePattern: 'cart/src/main/java',
                                        inclusionPattern: '**/*.class',
                                        changeBuildStatus: false
                                    )
                                }
                            }
                        }

                        stage('Code Quality') {
                            steps {
                                sh 'mvn checkstyle:checkstyle -pl cart -am -DskipTests'
                                echo 'Checkstyle report generated at: cart/target/checkstyle-result.xml'
                            }
                        }

                        stage('Security Scan') {
                            steps {
                                sh 'mvn -pl cart org.owasp:dependency-check-maven:check -DfailBuildOnCVSS=7 || true'
                            }
                            post {
                                always {
                                    publishHTML target: [
                                        allowMissing: true,
                                        alwaysLinkToLastBuild: false,
                                        keepAll: true,
                                        reportDir: 'cart/target',
                                        reportFiles: 'dependency-check-report.html',
                                        reportName: 'OWASP Dependency-Check Report'
                                    ]
                                }
                            }
                        }
                    }
                }

                // ─── Phase 2: Build ────────────────────────────────────────
                stage('Phase 2: Build') {
                    stages {
                        stage('Compile & Package') {
                            steps {
                                sh 'mvn clean install -pl cart -am -DskipTests'
                            }
                        }

                        stage('Build & Push Docker Image') {
                            when { 
                                anyOf {
                                    branch 'main'
                                    branch 'develop'
                                }
                            }
                            steps {
                                withCredentials([usernamePassword(
                                    credentialsId: 'docker-registry-credentials',
                                    usernameVariable: 'DOCKER_USER',
                                    passwordVariable: 'DOCKER_PASS'
                                )]) {
                                    sh """
                                        echo "\$DOCKER_PASS" | docker login ${DOCKER_REGISTRY} -u "\$DOCKER_USER" --password-stdin
                                        docker build -t ${DOCKER_IMAGE}:latest -t ${DOCKER_IMAGE}:${BUILD_NUMBER} ./cart
                                        docker push ${DOCKER_IMAGE}:latest
                                        docker push ${DOCKER_IMAGE}:${BUILD_NUMBER}
                                        docker logout ${DOCKER_REGISTRY}
                                    """
                                }
                            }
                        }
                    }
                }
            } // end nested stages
        } // end stage('CI')
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "✓ Cart service build completed successfully"
        }
        failure {
            echo "✗ Cart service build failed"
        }
    }
}
