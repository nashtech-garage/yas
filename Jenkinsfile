pipeline {
    agent any

    stages {
        stage('Test Phase') {
            steps {
                echo 'Bắt đầu chạy Test...'
                // Sau này Thành viên 2 sẽ thêm lệnh chạy Unit Test vào đây
            }
        }
        stage('Build Phase') {
            steps {
                echo 'Bắt đầu Build...'
                // Đây là nơi em sẽ viết lệnh build Docker image
            }
        }
    }
}