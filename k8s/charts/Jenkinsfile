pipeline {
    agent any

    environment {
        CHARTS_DIR          = 'k8s/charts'
        OWNER               = 'danzgne'
        REPO                = 'devops'
        CR_PACKAGE_PATH     = '.cr-release-packages'
        CR_INDEX_PATH       = '.cr-index'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 15, unit: 'MINUTES')
    }

    stages {
        stage('Release Charts') {
            when {
                allOf {
                    // branch 'main'
                    anyOf {
                        changeset 'k8s/charts/**'
                        expression { return currentBuild.changeSets.isEmpty() }
                    }
                }
            }
            stages {
                stage('Checkout') {
                    steps {
                        checkout([
                            $class: 'GitSCM',
                            branches: scm.branches,
                            userRemoteConfigs: scm.userRemoteConfigs,
                            extensions: [[$class: 'CloneOption', depth: 0, noTags: false]]
                        ])
                    }
                }

                stage('Configure Git') {
                    steps {
                        sh """
                            git config user.email "jenkins@yas.local"
                            git config user.name "Jenkins"
                        """
                    }
                }

                stage('Install Tools') {
                    steps {
                        sh """
                            # Install Helm into workspace .tools directory
                            mkdir -p \"\$WORKSPACE/.tools\"
                            HELM_VERSION="v3.20.1"
                            curl -sSLo helm.tar.gz "https://get.helm.sh/helm-\${HELM_VERSION}-linux-amd64.tar.gz"
                            tar -xzf helm.tar.gz
                            mv linux-amd64/helm \"\$WORKSPACE/.tools/helm\"
                            chmod +x \"\$WORKSPACE/.tools/helm\"
                            rm -rf helm.tar.gz linux-amd64

                            # Install chart-releaser (cr) into workspace .tools directory
                            CR_VERSION="1.6.1"
                            curl -sSLo cr.tar.gz \\
                              "https://github.com/helm/chart-releaser/releases/download/v\${CR_VERSION}/chart-releaser_\${CR_VERSION}_linux_amd64.tar.gz"
                            tar -xzf cr.tar.gz -C \"\$WORKSPACE/.tools\" cr
                            chmod +x \"\$WORKSPACE/.tools/cr\"
                            rm -f cr.tar.gz
                        """
                    }
                }

                stage('Add Helm Repo') {
                    steps {
                        sh """
                            export PATH=\"\$WORKSPACE/.tools:\$PATH\"
                            helm repo add stakater https://stakater.github.io/stakater-charts
                            helm repo update
                        """
                    }
                }

                stage('Package Charts') {
                    steps {
                        sh """
                            export PATH=\"\$WORKSPACE/.tools:\$PATH\"
                            mkdir -p ${CR_PACKAGE_PATH}
                            cr package k8s/charts/* --package-path ${CR_PACKAGE_PATH}
                        """
                    }
                }

                stage('Upload Releases') {
                    steps {
                        withCredentials([string(credentialsId: 'github-token', variable: 'CR_TOKEN')]) {
                            sh """
                                export PATH=\"\$WORKSPACE/.tools:\$PATH\"
                                cr upload \\
                                  --owner ${OWNER} \\
                                  --git-repo ${REPO} \\
                                  --package-path ${CR_PACKAGE_PATH} \\
                                  --token \$CR_TOKEN \\
                                  --skip-existing
                            """
                        }
                    }
                }

                stage('Update Index') {
                    steps {
                        withCredentials([string(credentialsId: 'github-token', variable: 'CR_TOKEN')]) {
                            sh """
                                export PATH=\"\$WORKSPACE/.tools:\$PATH\"
                                mkdir -p ${CR_INDEX_PATH}
                                cr index \\
                                  --owner ${OWNER} \\
                                  --git-repo ${REPO} \\
                                  --package-path ${CR_PACKAGE_PATH} \\
                                  --index-path ${CR_INDEX_PATH} \\
                                  --token \$CR_TOKEN \\
                                  --push
                            """
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo 'Charts released successfully'
        }
        failure {
            echo 'Chart release failed'
        }
    }
}
