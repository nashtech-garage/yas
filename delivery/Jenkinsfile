pipeline {
    agent any

    environment {
        SERVICE_NAME    = 'delivery'
        DOCKER_REGISTRY = 'ghcr.io'
        DOCKER_IMAGE    = "${DOCKER_REGISTRY}/nashtech-garage/yas-${SERVICE_NAME}"
    }

    tools {
        jdk   'jdk-21'
        maven 'maven-3'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    stages {
        // Guard: skip this pipeline entirely if nothing in this service changed.
        // changeSets is empty on the first scan of a new branch — build in that case.
        // For PR builds Jenkins compares against the target branch automatically.
        stage('CI') {
            when {
                anyOf {
                    changeset 'delivery/**'
                    changeset 'pom.xml'
                    expression { return currentBuild.changeSets.isEmpty() }
                }
            }
            stages {
                stage('Checkout') {
                    steps {
                        checkout scm
                    }
                }

                stage('Build') {
                    steps {
                        sh 'mvn clean install -pl delivery -am -DskipTests'
                    }
                }

                stage('Test') {
                    steps {
                        sh 'mvn test jacoco:report -pl delivery -am'
                    }
                    post {
                        always {
                            junit testResults: 'delivery/**/surefire-reports/TEST*.xml',
                                  allowEmptyResults: true
                            jacoco(
                                execPattern: 'delivery/target/jacoco.exec',
                                classPattern: 'delivery/target/classes',
                                sourcePattern: 'delivery/src/main/java',
                                inclusionPattern: '**/*.class',
                                changeBuildStatus: false
                            )
                        }
                    }
                }

                stage('Checkstyle') {
                    steps {
                        sh 'mvn checkstyle:checkstyle -pl delivery -am -Dcheckstyle.output.file=delivery-checkstyle-result.xml'
                    }
                }

                stage('SonarQube Analysis') {
                    steps {
                        withSonarQubeEnv('SonarQube') {
                            sh 'mvn org.sonarsource.scanner.maven:sonar-maven-plugin:sonar -pl delivery -am'
                        }
                    }
                }

                stage('OWASP Dependency Check') {
                    steps {
                        sh 'mvn -pl delivery org.owasp:dependency-check-maven:check -DfailBuildOnCVSS=7'
                    }
                    post {
                        always {
                            dependencyCheckPublisher pattern: 'delivery/target/dependency-check-report.xml'
                        }
                    }
                }
            } // end nested stages
        } // end stage('CI')
    }

    post {
        always {
            cleanWs()
        }
        failure {
            echo "Build failed for service: ${SERVICE_NAME}"
        }
    }
}
